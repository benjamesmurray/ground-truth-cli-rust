{
  "rule_registry": [
    {
      "id": "TS1",
      "trigger": "array iteration",
      "behavior": "No for...in. Use for...of or .map()/.filter().",
      "example": "Correct: for (const x of items)"
    },
    {
      "id": "TS2",
      "trigger": "I/O, fallible calls",
      "behavior": "No throw. Return Result union: {ok:true, val:T} | {ok:false, err:E}.",
      "example": "Correct: return { ok: true, val: data };"
    },
    {
      "id": "TS3",
      "trigger": "external/untyped data",
      "behavior": "No 'any' or 'as'. Use 'unknown' + Zod/Type Guards.",
      "example": "Correct: Schema.parse(input);"
    },
    {
      "id": "TS4",
      "trigger": "constants, status sets",
      "behavior": "No enums. Use string literal unions.",
      "example": "Correct: type S = 'on' | 'off';"
    },
    {
      "id": "N01",
      "trigger": "Next.js forms, mutations",
      "behavior": "useActionState + Zod-validated Server Action + FormState.",
      "example": "Correct: const [s, a] = useActionState(f, n);"
    },
    {
      "id": "A01",
      "trigger": "AWS Lambda, cloud",
      "behavior": "No monolithic aws-sdk. Import specific clients/commands from @aws-sdk/client-*.",
      "example": "Correct: import { S3Client } from '@aws-sdk/client-s3';"
    },
    {
      "id": "F01",
      "trigger": "Fastify endpoints",
      "behavior": "Apply RouteGenericInterface for Body/Params/Reply. No 'req' mutation without declaration merging.",
      "example": "Correct: fastify.post<Route>(...)"
    },
    {
      "id": "AG1",
      "trigger": "LLM tools, agentic workflows",
      "behavior": "Zod validation for all outputs/params. Use state machines (ReAct), not ad-hoc recursion.",
      "example": "Correct: ToolSchema.parse(output);"
    }
  ],
  "architecture_map": {
    "NextJS_App_Router": ["TS1", "TS2", "TS3", "TS4", "N01"],
    "AWS_Lambda_Serverless": ["TS1", "TS2", "TS3", "TS4", "A01"],
    "Fastify_High_Performance_API": ["TS1", "TS2", "TS3", "TS4", "F01"],
    "Agentic_Orchestration": ["TS1", "TS2", "TS3", "TS4", "AG1"]
  }
}
